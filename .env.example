# ==============================================================================
# Disaggregated LLM Serving — Environment Configuration
# ==============================================================================
# This file is AUTO-GENERATED by infra/setup_gcp.sh after GPU zone discovery.
# Only HF_TOKEN needs to be filled in manually.
#
# To regenerate: bash infra/setup_gcp.sh
# ==============================================================================

# --- GCP Infrastructure Metadata (auto-populated) ---
PREFILL_PROJECT=coms-6998-amlc
DECODE_PROJECT=coms-6998-hpml-487106
PREFILL_ZONE=<auto-discovered>
DECODE_ZONE=<auto-discovered>
PREFILL_REGION=<auto-discovered>
DECODE_REGION=<auto-discovered>
PREFILL_VM_NAME=prefill-worker-vm
DECODE_VM_NAME=decode-worker-vm
PLACEMENT_MODE=<same-region|cross-region>

# --- VM Network Addresses (auto-populated) ---
PREFILL_INTERNAL_IP=<auto-discovered>
PREFILL_EXTERNAL_IP=<auto-discovered>
DECODE_INTERNAL_IP=<auto-discovered>
DECODE_EXTERNAL_IP=<auto-discovered>

# --- HuggingFace ---
# Access token with permission for meta-llama/Meta-Llama-3-8B-Instruct
# !! THIS IS THE ONLY FIELD YOU NEED TO FILL IN MANUALLY !!
HF_TOKEN=hf_your_token_here

# --- Model ---
MODEL_NAME=meta-llama/Meta-Llama-3-8B-Instruct

# --- API Gateway ---
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# --- Prefill Worker ---
PREFILL_WORKER_HOST=<auto-populated from PREFILL_INTERNAL_IP>
PREFILL_WORKER_PORT=8001

# --- Decode Worker ---
DECODE_WORKER_HOST=<auto-populated from DECODE_INTERNAL_IP>
DECODE_WORKER_PORT=8002

# --- ZMQ KV-Cache Streaming ---
# The Decode Worker binds on this port; the Prefill Worker connects to it.
ZMQ_PORT=5555
